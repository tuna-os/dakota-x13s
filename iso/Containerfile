# Dakota X13s live ISO installer image
#
# Build with:
#   just container x13s
#
# Three-stage build:
#   1. dakota-x13s-ref   — source of kernel modules + X13s DTB
#   2. initramfs-builder — Debian arm64: builds a dmsquash-live initramfs
#                          against the dakota-x13s kernel modules
#   3. final             — dakota-x13s: receives the rebuilt initramfs + live env
#
# dakota-x13s is GNOME OS / freedesktop-sdk based — no dnf, no dracut in image.
# The initramfs is built in a separate Debian arm64 stage; only initramfs.img
# crosses the stage boundary.
# The ISO bootloader is systemd-boot (systemd-bootaa64.efi already in the image).

# ── Stage 1: dakota-x13s reference (kernel modules + DTB source) ─────────────
FROM ghcr.io/tuna-os/dakota-x13s:latest AS dakota-ref

# ── Stage 2: Debian arm64 — builds the dmsquash-live initramfs ───────────────
FROM --platform=linux/arm64 debian:sid AS initramfs-builder

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        dracut \
        dmsetup \
        linux-image-arm64 \
    && rm -rf /var/lib/apt/lists/*

# Import dakota-x13s kernel module tree so dracut targets the correct kernel
COPY --from=dakota-ref /usr/lib/modules /usr/lib/modules

RUN set -ex; \
    kernel=$(ls /usr/lib/modules | sort -V | tail -1); \
    echo "Building dmsquash-live initramfs for kernel ${kernel}"; \
    DRACUT_NO_XATTR=1 dracut -v --force --zstd --reproducible --no-hostonly \
        --add "dmsquash-live" \
        --add-drivers "squashfs overlay loop iso9660 sr_mod cdrom" \
        /tmp/initramfs.img "${kernel}"; \
    ls -lh /tmp/initramfs.img

# Extract X13s DTB from Debian kernel package
RUN DTB=$(find /usr/lib/linux-image* -name "sc8280xp-lenovo-thinkpad-x13s.dtb" 2>/dev/null | head -1); \
    [ -n "$DTB" ] || { echo "ERROR: sc8280xp-lenovo-thinkpad-x13s.dtb not found in linux-image-arm64" >&2; exit 1; }; \
    echo "DTB: $DTB"; \
    cp "$DTB" /tmp/x13s.dtb

# ── Stage 3: Final dakota-x13s live image ────────────────────────────────────
FROM ghcr.io/tuna-os/dakota-x13s:latest

ARG INSTALLER_CHANNEL=stable
ENV INSTALLER_CHANNEL=${INSTALLER_CHANNEL}

ARG DEBUG=0
ENV DEBUG=${DEBUG}

# Replace the OCI-mode initramfs with the dmsquash-live initramfs from stage 2.
# Also install the X13s DTB (Debian kernel package ships it; GNOME OS kernel doesn't).
# The DTB is placed in the standard modules path so build-iso.sh picks it up.
COPY --from=initramfs-builder /tmp/initramfs.img /tmp/initramfs.img
COPY --from=initramfs-builder /tmp/x13s.dtb /tmp/x13s.dtb
RUN kernel=$(ls /usr/lib/modules | sort -V | tail -1) && \
    mv /tmp/initramfs.img "/usr/lib/modules/${kernel}/initramfs.img" && \
    mkdir -p "/usr/lib/modules/${kernel}/dtb/qcom" && \
    mv /tmp/x13s.dtb "/usr/lib/modules/${kernel}/dtb/qcom/sc8280xp-lenovo-thinkpad-x13s.dtb" && \
    echo "Replaced initramfs for kernel ${kernel}" && \
    echo "Installed X13s DTB for kernel ${kernel}"

# ── Flatpak install layer ─────────────────────────────────────────────────────
COPY src/flatpaks /tmp/flatpaks-list
RUN --mount=type=bind,source=src,target=/src \
    --mount=type=cache,target=/var/cache/flatpak-dl,id=dakota-x13s-flatpak \
    /src/install-flatpaks.sh

# ── Live-environment configure layer ─────────────────────────────────────────
COPY src/ /tmp/src/
RUN chmod +x /tmp/src/configure-live.sh && /tmp/src/configure-live.sh
